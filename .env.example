MT5_LOGIN=your_demo_account_number
MT5_PASSWORD=your_demo_account_password
MT5_SERVER=your_broker_server_name

# Telegram — required for signal_only mode (and for live-mode alerts).
# Create a bot via @BotFather and grab the chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
